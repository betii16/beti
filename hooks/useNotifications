'use client'

// ================================================================
// hooks/useNotifications.ts
// Hook pour les notifications temps réel BETI
// ================================================================

import { useEffect, useState, useCallback } from 'react'
import { createClient } from '@supabase/supabase-js'



export type Notification = {
  id: string
  type: 'new_booking' | 'booking_accepted' | 'booking_refused' | 'booking_completed' | 'new_review'
  title: string
  body: string
  is_read: boolean
  created_at: string
  data?: any
}

export type Booking = {
  id: string
  title: string
  description?: string
  address: string
  scheduled_at: string
  status: string
  client?: { full_name: string; phone?: string }
}

// ── Hook notifications ────────────────────────────────────────────

export function useNotifications(userId: string | null) {
  const [notifications, setNotifications] = useState<Notification[]>([])
  const [unreadCount, setUnreadCount] = useState(0)

  // Charger les notifications existantes
  const loadNotifications = useCallback(async () => {
    if (!userId) return
    const { data } = await supabase
      .from('notifications')
      .select('*')
      .eq('user_id', userId)
      .order('created_at', { ascending: false })
      .limit(50)
    if (data) {
      setNotifications(data)
      setUnreadCount(data.filter(n => !n.is_read).length)
    }
  }, [userId])

  // Marquer toutes comme lues
  const markAllRead = useCallback(async () => {
    if (!userId) return
    await supabase
      .from('notifications')
      .update({ is_read: true })
      .eq('user_id', userId)
      .eq('is_read', false)
    setNotifications(prev => prev.map(n => ({ ...n, is_read: true })))
    setUnreadCount(0)
  }, [userId])

  // Marquer une comme lue
  const markRead = useCallback(async (id: string) => {
    await supabase.from('notifications').update({ is_read: true }).eq('id', id)
    setNotifications(prev => prev.map(n => n.id === id ? { ...n, is_read: true } : n))
    setUnreadCount(prev => Math.max(0, prev - 1))
  }, [])

  // Écoute temps réel
  useEffect(() => {
    if (!userId) return
    loadNotifications()

    const channel = supabase
      .channel(`notifications-${userId}`)
      .on('postgres_changes', {
        event: 'INSERT',
        schema: 'public',
        table: 'notifications',
        filter: `user_id=eq.${userId}`,
      }, (payload) => {
        const newNotif = payload.new as Notification
        setNotifications(prev => [newNotif, ...prev])
        setUnreadCount(prev => prev + 1)
        // Notification navigateur
        if (Notification.permission === 'granted') {
          new Notification(newNotif.title, { body: newNotif.body, icon: '/icon.png' })
        }
      })
      .subscribe()

    return () => { supabase.removeChannel(channel) }
  }, [userId, loadNotifications])

  return { notifications, unreadCount, markAllRead, markRead, loadNotifications }
}

// ── Hook réservations artisan (temps réel) ────────────────────────

export function useArtisanBookings(artisanId: string | null) {
  const [bookings, setBookings] = useState<Booking[]>([])
  const [newBooking, setNewBooking] = useState<Booking | null>(null)

  const loadBookings = useCallback(async () => {
    if (!artisanId) return
    const { data } = await supabase
      .from('bookings')
      .select('*, profiles!bookings_client_id_fkey(full_name, phone)')
      .eq('artisan_id', artisanId)
      .order('created_at', { ascending: false })
    if (data) setBookings(data)
  }, [artisanId])

  const updateStatus = useCallback(async (bookingId: string, status: string) => {
    await supabase.from('bookings').update({ status }).eq('id', bookingId)
    setBookings(prev => prev.map(b => b.id === bookingId ? { ...b, status } : b))
  }, [])

  useEffect(() => {
    if (!artisanId) return
    loadBookings()

    const channel = supabase
      .channel(`bookings-artisan-${artisanId}`)
      .on('postgres_changes', {
        event: 'INSERT',
        schema: 'public',
        table: 'bookings',
        filter: `artisan_id=eq.${artisanId}`,
      }, async (payload) => {
        // Charger les infos client
        const { data } = await supabase
          .from('profiles')
          .select('full_name, phone')
          .eq('id', payload.new.client_id)
          .single()
        const booking = { ...payload.new, client: data } as Booking
        setNewBooking(booking)
        setBookings(prev => [booking, ...prev])
      })
      .subscribe()

    return () => { supabase.removeChannel(channel) }
  }, [artisanId, loadBookings])

  return { bookings, newBooking, setNewBooking, updateStatus, loadBookings }
}
